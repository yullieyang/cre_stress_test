# Required: FRED API key (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Optional: Boston Open Data CKAN resource ID for zoning data
# Find at https://data.boston.gov/ → search "zoning" → copy resource UUID
BOSTON_ZONING_RESOURCE_ID=

# Optional: Anthropic API key for the LLM commentary module
# Get at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override default paths
DATA_DIR=data
OUTPUTS_DIR=outputs
DATABASE_URL=sqlite:///cre_stress.db
